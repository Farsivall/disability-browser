# Google Gemini API key (free tier: https://aistudio.google.com/apikey).
# The agent uses the native Google Gen AI SDK (langchain-google-genai) on
# gemini-3.5-flash. See FROZEN.md "LLM provider" in the repo root for why.
GEMINI_API_KEY=your-gemini-key

# Optional override. Defaults to gemini-3.5-flash.
# MODEL=gemini-3.5-flash

# Linkup web-search API key (https://app.linkup.so). Powers the `web_search`
# tool wired into the dynamic agent (agent/src/linkup_tools.py). Optional —
# if unset, web_search returns a friendly "not configured" message and the
# agent falls back to PDF-only answers.
LINKUP_API_KEY=your-linkup-key
