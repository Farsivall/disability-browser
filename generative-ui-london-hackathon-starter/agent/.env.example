# Google Gemini API key (free tier: https://aistudio.google.com/apikey).
# The agent uses the native Google Gen AI SDK (langchain-google-genai) on
# gemini-3.5-flash. See FROZEN.md "LLM provider" in the repo root for why.
GEMINI_API_KEY=your-gemini-key

# Optional override. Defaults to gemini-3.5-flash.
# MODEL=gemini-3.5-flash

# Optional. Linkup web-search key for the /perceptual agent's enrichment step.
# Auto-on when set; silently skipped (profiles-only generation) when absent,
# slow, or erroring. Free key: https://www.linkup.so/
# LINKUP_API_KEY=
