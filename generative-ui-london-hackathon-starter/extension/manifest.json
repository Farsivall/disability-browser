{
  "manifest_version": 3,
  "name": "Perceptual Web",
  "description": "Accessibility agent: regenerates pages tailored to how each user struggles.",
  "version": "0.1.0",

  "permissions": [
    "sidePanel",
    "scripting",
    "activeTab",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "side-panel/host.html"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src http://localhost:3000 http://127.0.0.1:3000;"
  },

  "action": {
    "default_title": "Open Perceptual Web"
  }
}
